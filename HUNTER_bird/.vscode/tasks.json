{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build hunter",
      "type": "shell",
      "command": "gcc",
      "args": [
        "src/main.c",
        "src/game.c",
        "-Iinclude",
        "-o",
        "game",
        "-lSDL2",
        "-lSDL2_image",
        "-lSDL2_mixer",
        "-lSDL2_ttf",
        "-lm"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
