{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Game",
      "type": "shell",
      "command": "gcc",
      "args": [
        "*.c",
        "-I../include",
        "-o",
        "game.exe",
        "-lmingw32",
        "-lSDL2main",
        "-lSDL2",
        "-lSDL2_ttf",
        "-lSDL2_image",
        "-lSDL2_mixer"
      ],
      "group": "build"
    }
  ]
}